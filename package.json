{
  "name": "crumb-widget",
  "version": "1.3.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bmlt-enabled/crumb-widget.git"
  },
  "files": [
    "dist/module.js",
    "dist/module.d.ts"
  ],
  "module": "./dist/module.js",
  "types": "./dist/module.d.ts",
  "exports": {
    ".": {
      "import": "./dist/module.js",
      "types": "./dist/module.d.ts"
    }
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "lint": "prettier --check vite.config.ts vite.lib.config.ts tsconfig.json src && eslint vite.config.ts vite.lib.config.ts src && svelte-check --tsconfig ./tsconfig.json",
    "format": "prettier --write vite.config.ts vite.lib.config.ts tsconfig.json src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "size": "size-limit",
    "all": "npm run format && npm run lint && npm run test && npm run build"
  },
  "size-limit": [
    {
      "name": "dist/module.js (gzip)",
      "path": "dist/module.js",
      "limit": "120 kB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.1.17",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.2.9",
    "@tsconfig/svelte": "^5.0.6",
    "@types/leaflet": "^1.9.18",
    "@types/node": "^25.2.0",
    "@vitest/coverage-v8": "^4.1.2",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.13.0",
    "globals": "^17.4.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.6.2",
    "prettier-plugin-svelte": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "size-limit": "^12.0.1",
    "svelte": "^5.44.1",
    "svelte-check": "^4.3.4",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.48.0",
    "unplugin-dts": "^1.0.0",
    "vite": "^8.0.5",
    "vite-plugin-css-injected-by-js": "^5.0.0",
    "vitest": "^4.0.14"
  },
  "dependencies": {
    "@bmlt-enabled/svelte-spa-router": "^5.2.0",
    "bmlt-query-client": "^1.1.0",
    "localized-strings": "^2.0.3"
  },
  "peerDependencies": {
    "leaflet": "^1.9.4"
  },
  "engines": {
    "node": ">=22"
  }
}
